# Intelligent Excel Services — environment template
# Copy this file to .env and fill in real values. .env is gitignored.

# Application Settings
APP_NAME="Intelligent Excel Services"
APP_VERSION="0.1.0"
ENVIRONMENT=development
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/intellegent-excel"
DATABASE_ECHO=false
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=5
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_POOL_PRE_PING=true

# Redis
REDIS_URL="redis://localhost:6379/0"

# Rate Limiting
RATE_LIMIT_ENABLED=true

# Cache
CACHE_ENABLED=true
CACHE_DEFAULT_TTL=300
CACHE_MAX_CONNECTIONS=50
CACHE_RETRY_ON_TIMEOUT=true
CACHE_SOCKET_TIMEOUT=5

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=console

# OpenTelemetry
OTEL_SERVICE_NAME="excel-services"
OTEL_SERVICE_VERSION="0.1.0"

# Jaeger
JAEGER_ENABLED=false
JAEGER_LOGS_ENABLED=false
JAEGER_AGENT_URL="http://localhost:4318"
TRACE_SAMPLING_RATE=1.0

# Prometheus
ENABLE_METRICS=false

# Security Headers
SECURITY_HEADERS_ENABLED=true
X_FRAME_OPTIONS=DENY
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false
REFERRER_POLICY=strict-origin-when-cross-origin
CSP_ENABLED=true
CSP_DISABLE_IN_DEVELOPMENT=false
REMOVE_SERVER_HEADER=true

# CORS
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_ALL_ORIGINS=true
CORS_MAX_AGE=86400

# JWT
JWT_SECRET_KEY="change-me-in-production"
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Google OAuth — fill from your Google Cloud Console project
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:8000/api/v1/auth/google/callback"

# LLM provider used by Akash's legacy code-gen agent
OPENAI_API_KEY=""
AGENT_LLM_PROVIDER="openai"
AGENT_LLM_MODEL="gpt-4o"

# Rosetta (our coordinator) uses Anthropic Claude
# Set this for the coordinator to answer questions; leave empty to fall back to legacy agent
ANTHROPIC_API_KEY=""
ROSETTA_MODEL="claude-sonnet-4-5"

# Feature flag: when true, /ask calls the legacy code-gen agent instead of the Rosetta coordinator.
# Default false (Rosetta coordinator runs). Set to true for rollback.
USE_LEGACY_AGENT=false

# Qdrant
QDRANT_HOST="localhost"
QDRANT_PORT=6333
QDRANT_API_KEY=""
QDRANT_PREFER_GRPC=false
KNOWLEDGE_COLLECTION_NAME="excel_knowledge"

# Vector Embeddings (OpenAI)
EMBEDDING_PROVIDER="openai"
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_DIMENSION=1536
EMBEDDING_BATCH_SIZE=100
